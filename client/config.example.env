WORKER_BASE_URL=https://sub.050721.xyz
ADMIN_TOKEN=replace-with-your-admin-token
SUB_ACCESS_TOKEN=

TOP_N=200
OUTPUT_FORMAT=clash
KEEP_ORIGINAL_HOST=true

# 主候选模式：
# - cfst_ipv4_ranges: 默认使用 CloudflareSpeedTest 的 ip.txt IPv4 段
# - hybrid: 在默认 IPv4 段基础上，再合并 ADD / ADDAPI / ADDCSV
# - custom_only: 只使用 ADD / ADDAPI / ADDCSV
CANDIDATE_SOURCE_MODE=cfst_ipv4_ranges

# Project 1 风格的补充候选源。只会提取其中的 IP / CIDR，域名会被忽略。
ADD=
ADDAPI=
ADDCSV=
DLS=0
ENABLE_IPV6=false

# CFST 运行参数
LATENCY_THREADS=200
LATENCY_PING_COUNT=4
DOWNLOAD_TEST_COUNT=200
DOWNLOAD_TEST_SECONDS=10
TEST_PORT=443
TEST_URL=
USE_HTTPING=false
HTTPING_STATUS_CODE=
LATENCY_UPPER_MS=9999
LATENCY_LOWER_MS=0
LOSS_RATE_UPPER=1.00
MIN_SPEED_MBPS=0
CF_COLO_FILTER=
CFST_EXTRA_ARGS=

# 高级选项
UPDATE_SOURCE=local-cli-optimize
CLIENT_WORKDIR=
CFST_BIN=
CFST_RELEASE_API=https://api.github.com/repos/XIU2/CloudflareSpeedTest/releases/latest
CFST_IP_FILE=
CFST_IPV6_FILE=
